# Copy to .dev.vars and fill in. Used by "npm run preview" (Wrangler local).
# Get the preview URL from the terminal (e.g. http://127.0.0.1:8787) and set NEXTAUTH_URL to it.
# Add that URL to Google OAuth: http://127.0.0.1:8787/api/auth/callback/google
#
# Optional: TRAK_D1_TEST_SECRET - when set, POST /api/profile with header
#   x-trak-d1-test: <this-secret>
# allows saving a test profile without signing in (for testing D1 in preview).

NEXTAUTH_SECRET=your-secret
NEXTAUTH_URL=http://127.0.0.1:8787
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
TRAK_D1_TEST_SECRET=your-random-test-secret
