# NextAuth (required for Google login)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth – create at https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application), add redirect URI:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Rive animation on login button (path or URL to .riv file)
# NEXT_PUBLIC_RIVE_CTA_URL=/trak-logo.riv
